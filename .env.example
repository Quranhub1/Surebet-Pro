# Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# Football-Data.org API Key (Required)
# Get a free key at: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# AI Provider API Keys (Optional - at least one recommended)
# Groq - Free tier available
GROQ_API_KEY=your_groq_api_key_here

# OpenAI - $5 free credit
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace - Free inference API
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Cohere - Free: 5M tokens/month
COHERE_API_KEY=your_cohere_api_key_here

# Anthropic - $5 free credit
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI - Gemini 2.0 Flash free tier
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
