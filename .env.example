# Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# API-Football (RapidAPI) - Recommended for 200+ worldwide matches
# Get key at: https://rapidapi.com/api-football/api/api-football
RAPIDAPI_KEY=your_rapidapi_key_here

# Football-Data.org API Key (Fallback)
# Get a free key at: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# AI Provider API Keys (Optional - at least one recommended)

# Groq - Free tier available (Ultra-low latency)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI - $5 free credit
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace - Free inference API
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Cohere - Free: 5M tokens/month
COHERE_API_KEY=your_cohere_api_key_here

# Anthropic - $5 free credit
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI - Gemini 2.0 Flash free tier
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# OpenRouter - Access to 100+ models (Llama, GPT, Claude, etc.)
# Get key at: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# GitHub Models - Access to Azure-hosted models
# Get key at: https://github.com/marketplace/models
GITHUB_MODELS_API_KEY=your_github_models_api_key_here

# Z.ai - AI provider
Z_AI_API_KEY=your_z_ai_api_key_here

# Deployment Keys

# Railway API Key (for deployment)
RAILWAY_API_KEY=your_railway_api_key_here

# GitHub Token (for GitHub Models)
GITHUB_TOKEN=your_github_token_here

# Application Settings

# Default AI Provider (groq, openai, cohere, openrouter, github, etc.)
DEFAULT_AI_PROVIDER=groq

# Daily betting target
DAILY_TARGET=100
